            <setvar action="Set" varname="SCORE">100</setvar>
          </respcondition>
          <respcondition>
            <conditionvar>
              <varequal respident="id84a8901-b2cc-47b7-a93c-e972802c8e04">ib39fd1f3-ada0-4229-becf-5665df1b32ec</varequal>
