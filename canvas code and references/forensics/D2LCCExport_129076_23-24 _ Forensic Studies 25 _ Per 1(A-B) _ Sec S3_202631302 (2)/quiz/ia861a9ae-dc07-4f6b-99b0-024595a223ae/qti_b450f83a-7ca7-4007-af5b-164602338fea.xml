        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;The reason it is important to seperate the witnesses at the crime scene is to:&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="iac83fe24-b4a0-4d76-83fa-54282edc23ec" rcardinality="Single">
            <render_choice shuffle="Yes">
              <response_label ident="i611ca6d3-7585-420e-84a7-efe46761c47a">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Prevent contamination of the evidence&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="i29fba478-0472-4c8f-a37f-faefe086308c">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Prevent fighting among the witnesses&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="ic3f1455e-dc36-47d8-a43f-c7964be40929">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Prevent the witnesses from talking to each other&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="if7f753ca-ab63-447a-a112-51ba1f6d8644">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;Prevent them from seeing the perpetrator&lt;/p&gt;</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
