        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;A forensic scientist is trying to identify the source of numerous hair samples found on a homicide victim.&amp;nbsp; The hairs all display frayed root tips, spinous cuticle scales and unisereal medullas. What is the source of this hair?&lt;br&gt;&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="id5cbce2a-bad3-4bde-8ffa-3f73a68d477d" rcardinality="Single">
            <render_choice shuffle="Yes">
              <response_label ident="ie547575c-0d89-419d-81e8-ec71326ba4ee">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;a cat&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="i510afc9d-fb53-4281-bb60-53952fb35ed0">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;a dog&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="i58398bf2-e74e-447e-927d-3703db87040a">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;a human&lt;/p&gt;</mattext>
                </material>
              </response_label>
              <response_label ident="ia5e85313-4695-4e3a-adee-991b74cb99c9">
                <material>
                  <mattext texttype="text/html">&lt;p&gt;a rabbit&lt;/p&gt;</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar minvalue="0" maxvalue="100" varname="SCORE" vartype="Decimal" />
          </outcomes>
          <respcondition continue="No">
            <conditionvar>
              <varequal respident="id5cbce2a-bad3-4bde-8ffa-3f73a68d477d">ie547575c-0d89-419d-81e8-ec71326ba4ee</varequal>
            </conditionvar>
